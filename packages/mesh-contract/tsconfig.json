{
  "extends": "@meshsdk/configs/typescript/base.json",
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule":true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
